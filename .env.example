# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/specialtyrx

# JWT
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRE=7d

# Anthropic
